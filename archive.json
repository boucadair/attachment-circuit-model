      "headRepository": "robric/attachment-circuit-model",
      "headRefName": "patch-1",
      "headRefOid": "6f590e41b910e7c62521420452f56076040a6e9d",
      "closedAt": "2022-12-13T15:22:09Z",
      "mergedAt": "2022-12-13T15:22:09Z",
